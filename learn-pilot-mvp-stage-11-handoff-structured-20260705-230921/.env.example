# Local PostgreSQL for MVP development.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/learn_pilot_mvp?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/learn_pilot_mvp?schema=public"

# Demo-user MVP: real authentication is intentionally deferred.
NEXTAUTH_SECRET="replace-with-local-secret"
NEXTAUTH_URL="http://localhost:3000"

# AI is mocked during early development. Keep real keys out of git.
OPENAI_API_KEY=""
OPENAI_MODEL="mock"

# Optional monitoring for deployed environments.
SENTRY_DSN=""
